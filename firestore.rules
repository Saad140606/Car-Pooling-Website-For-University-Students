rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    function isAdmin() { return isAuth() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function hasLegacyCancellationThreshold(userData) {
      return userData.totalParticipations is int
        && userData.totalCancellations is int
        && userData.totalParticipations >= 3
        && (userData.totalCancellations * 100) >= (35 * userData.totalParticipations);
    }
    function hasRoleCancellationThreshold(userData) {
      return (
        userData.driverCancellationPolicy is map
        && userData.driverCancellationPolicy.totalRidesWindow is int
        && userData.driverCancellationPolicy.cancellationRate is int
        && userData.driverCancellationPolicy.totalRidesWindow >= 3
        && userData.driverCancellationPolicy.cancellationRate >= 35
      ) || (
        userData.passengerCancellationPolicy is map
        && userData.passengerCancellationPolicy.totalRidesWindow is int
        && userData.passengerCancellationPolicy.cancellationRate is int
        && userData.passengerCancellationPolicy.totalRidesWindow >= 3
        && userData.passengerCancellationPolicy.cancellationRate >= 35
      );
    }
    function hasCancellationThreshold(userData) {
      return hasRoleCancellationThreshold(userData) || hasLegacyCancellationThreshold(userData);
    }
    function isRideActionLocked(univId) {
      return isAuth()
        && exists(/databases/$(database)/documents/universities/$(univId)/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/universities/$(univId)/users/$(request.auth.uid)).data.get('accountLockReason', null) == 'many_cancellations'
        && get(/databases/$(database)/documents/universities/$(univId)/users/$(request.auth.uid)).data.get('accountLockUntil', null) is timestamp
        && request.time < get(/databases/$(database)/documents/universities/$(univId)/users/$(request.auth.uid)).data.get('accountLockUntil', null)
        && hasCancellationThreshold(get(/databases/$(database)/documents/universities/$(univId)/users/$(request.auth.uid)).data);
    }

    match /admins/{adminId} {
      allow get: if isAuth() && request.auth.uid == adminId;
      allow create, update, delete, list: if false;
    }

    match /public_rides/{publicRideId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /contact_messages/{msgId} {
      allow create: if (
        request.resource.data.createdAt is timestamp
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 10
        && (request.resource.data.uid is string || request.resource.data.uid == null)
        && (request.resource.data.status in ['open', 'resolved'])
      );
      allow get, list, update, delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if isAuth()
        && request.resource.data.reportedBy.uid == request.auth.uid
        && request.resource.data.reportedBy.role in ['driver', 'passenger']
        && (request.resource.data.againstUserUid is string || request.resource.data.againstUserUid == null)
        && (request.resource.data.rideId is string || request.resource.data.rideId == null)
        && request.resource.data.category in ['misbehavior', 'safety', 'fraud', 'app_issue']
        && request.resource.data.description is string
        && request.resource.data.description.size() >= 10
        && request.resource.data.createdAt is timestamp
        && request.resource.data.status in ['pending', 'reviewed', 'action_taken'];
      allow get, list, update, delete: if isAdmin();
    }

    match /fcm_tokens/{uid} {
      allow create, update, delete, get: if isAuth() && request.auth.uid == uid;
      allow list: if false;
      match /throttles/{throttleId} {
        allow create, update, delete, get: if isAuth() && request.auth.uid == uid;
        allow list: if false;
      }
    }

    // Spark push flow (no Cloud Functions): user token mirror
    match /users/{userId} {
      allow get: if isAuth() && request.auth.uid == userId;
      allow list: if false;

      allow create, update: if isAuth()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'fcmToken',
          'fcmTokens',
          'fcmTokenUpdatedAt',
          'pushEnabled'
        ]);

      allow delete: if false;
    }

    // Spark push flow (example queue): top-level ride request docs
    match /rides/{rideId} {
      allow create: if isAuth()
        && request.resource.data.type == 'request'
        && (
          (request.resource.data.createdBy is string && request.resource.data.createdBy == request.auth.uid)
          || (request.resource.data.passengerId is string && request.resource.data.passengerId == request.auth.uid)
        );

      allow get, list: if isAuth();

      // Clients can only update lightweight notification/audit fields on docs they own.
      allow update: if isAuth()
        && (
          (resource.data.createdBy is string && resource.data.createdBy == request.auth.uid)
          || (resource.data.passengerId is string && resource.data.passengerId == request.auth.uid)
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'notificationSent',
          'notificationStatus',
          'notificationAttemptedAt',
          'notificationSentAt',
          'notificationSuccessCount',
          'notificationFailureCount',
          'notificationError'
        ]);

      allow delete: if isAdmin();
    }

    match /universities/{univId} {
      allow get, list: if true;

      match /users/{userId} {
        allow create: if isAuth()
          && request.auth.uid == userId
          && request.resource.data.university == univId
          && request.resource.data.email == request.auth.token.email
          && request.resource.data.createdAt is timestamp;

        allow get: if isAuth() && request.auth.uid == userId;
        allow list: if isAdmin();

        allow update, delete: if isAuth() && request.auth.uid == userId
          && request.resource.data.email == resource.data.email
          && request.resource.data.university == resource.data.university
          && request.resource.data.university == univId;
      }

      match /rides/{rideId} {
        allow get, list: if true;

        allow create: if isAuth()
          && !isRideActionLocked(univId)
          && (
            (request.resource.data.createdBy is string && request.resource.data.createdBy == request.auth.uid)
            || (request.resource.data.driverId is string && request.resource.data.driverId == request.auth.uid)
          )
          && request.resource.data.university == univId;

        allow update, delete: if isAdmin() || (isAuth() && (
          (resource.data.createdBy is string && resource.data.createdBy == request.auth.uid)
          || (resource.data.driverId is string && resource.data.driverId == request.auth.uid)
        ));

        allow update: if isAuth()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['confirmedPassengers', 'availableSeats', 'status', 'updatedAt'])
          && request.resource.data.confirmedPassengers.toSet().difference(resource.data.get('confirmedPassengers', []).toSet()).hasOnly([request.auth.uid]);

        match /requests/{requestId} {
          allow create: if isAuth() && !isRideActionLocked(univId) && request.resource.data.passengerId == request.auth.uid;
          allow get: if isAdmin() || (isAuth() && (
            (resource.data.passengerId is string && resource.data.passengerId == request.auth.uid)
            || (resource.data.driverId is string && resource.data.driverId == request.auth.uid)
            || requestId.matches('^' + rideId + '_' + request.auth.uid + '$')
          ));
          allow list: if isAdmin() || isAuth();
          allow update: if isAuth() && (
            (!isRideActionLocked(univId) && request.resource.data.passengerId == request.auth.uid && resource.size() == 0)
            || (
              (resource.data.passengerId is string && resource.data.passengerId == request.auth.uid)
              || (resource.data.driverId is string && resource.data.driverId == request.auth.uid)
              || isAdmin()
            )
          );
          allow delete: if isAdmin() || (isAuth() && (
            (resource.data.passengerId is string && resource.data.passengerId == request.auth.uid)
            || (resource.data.driverId is string && resource.data.driverId == request.auth.uid)
          ));
        }
      }

      match /bookings/{bookingId} {
        allow create: if isAuth() && (
          request.resource.data.passengerId == request.auth.uid
          || request.resource.data.driverId == request.auth.uid
        );
        allow get: if isAdmin() || (isAuth() && (
          resource.data.passengerId == request.auth.uid
          || resource.data.driverId == request.auth.uid
        ));
        allow list: if isAdmin() || isAuth();
        allow update, delete: if isAdmin() || (isAuth() && (
          resource.data.passengerId == request.auth.uid
          || resource.data.driverId == request.auth.uid
        ));
      }

      match /chats/{chatId} {
        allow create: if isAuth();
        allow get, list, update, delete: if isAdmin() || (isAuth() && (
          (resource.data.participants is list && request.auth.uid in resource.data.participants)
          || (resource.data.passengerId is string && resource.data.passengerId == request.auth.uid)
          || (resource.data.providerId is string && resource.data.providerId == request.auth.uid)
        ));

      match /messages/{messageId} { //IDOR FIX BY SHAMVEEL KHAN
          // Only authenticated users who are part of the chat can create a message
          allow create: if isAuth() 
            && request.resource.data.senderId == request.auth.uid
            && request.resource.data.senderId in resource.parent.data.participants;
        
          // Only participants can read or list messages
          allow get, list: if isAuth() && request.auth.uid in resource.parent.data.participants;
        
          // Only the sender can update their own message
          allow update: if isAuth() && request.auth.uid == resource.data.senderId;
        
          //  deletion is not allowed
          allow delete: if false;
        }
      }

      match /lifecycle_ratings/{ratingId} {
        allow create, update, delete: if false;
        allow get, list: if isAuth();
      }

      match /user_rating_stats/{userId} {
        allow get, list: if isAuth();
        allow create, update, delete: if false;
      }

      match /rideCompletions/{rideId} {
        allow get, list: if isAuth();
        allow create, update: if isAuth();
        allow delete: if isAdmin();
      }

      match /unreadEvents/{eventDocId} {
        allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
        allow get, list: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
        allow update: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin())
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.eventId == resource.data.eventId
          && request.resource.data.targetSection == resource.data.targetSection;
        allow delete: if isAdmin();
      }

      match /notifications/{notificationId} {
        allow create: if isAuth() && request.resource.data.userId is string;
        allow get, list: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
        allow update: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin())
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt', 'isDeleted']);
        allow delete: if isAdmin();
      }

      match /email_verifications/{uid} {
        allow create: if false;
        allow get: if isAuth() && request.auth.uid == uid;
        allow update, delete, list: if false;
      }

      match /calls/{callId} {
        allow create: if isAuth()
          && request.resource.data.callerId == request.auth.uid
          && request.resource.data.receiverId is string
          && request.resource.data.callType in ['audio', 'video']
          && request.resource.data.status in ['ringing', 'connected', 'rejected', 'missed', 'ended']
          && request.resource.data.createdAt is timestamp;

        allow get, update, delete: if isAuth() && (
          resource.data.callerId == request.auth.uid
          || resource.data.receiverId == request.auth.uid
        );
        allow list: if false;

        match /callerCandidates/{candidateId} {
          allow create, get, list, delete: if isAuth();
        }

        match /calleeCandidates/{candidateId} {
          allow create, get, list, delete: if isAuth();
        }
      }

      match /{document=**} {
        allow read: if isAdmin();
        allow write: if false;
      }
    }

    match /{document=**} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
