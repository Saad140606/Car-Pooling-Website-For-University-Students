rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic helpers
    function isAuth() { return request.auth != null; }
    function isAdmin() { return isAuth() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }

    // Admins collection (managed server-side)
    match /admins/{adminId} {
      allow get: if isAuth() && request.auth.uid == adminId;
      allow create, update, delete: if false;
    }

    // Public rides (readable by anyone)
    match /public_rides/{publicRideId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    // Contact messages: allow anonymous creation but validate payload
    match /contact_messages/{msgId} {
      allow create: if (
        request.resource.data.createdAt is timestamp
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 10
        && (request.resource.data.uid is string || request.resource.data.uid == null)
        && (request.resource.data.status in ['open', 'resolved'])
      );
      allow get, list, update, delete: if isAdmin();
    }

    // Reports: only authenticated users can create
    match /reports/{reportId} {
      allow create: if isAuth()
        && request.resource.data.reportedBy.uid == request.auth.uid
        && request.resource.data.reportedBy.role in ['driver', 'passenger']
        && (request.resource.data.againstUserUid is string || request.resource.data.againstUserUid == null)
        && (request.resource.data.rideId is string || request.resource.data.rideId == null)
        && request.resource.data.category in ['misbehavior','safety','fraud','app_issue']
        && request.resource.data.description is string
        && request.resource.data.description.size() >= 10
        && request.resource.data.createdAt is timestamp
        && request.resource.data.status in ['pending','reviewed','action_taken'];
      allow get, list, update, delete: if isAdmin();
    }

    // Universities and nested collections
    match /universities/{univId} {
      // Allow admins and authenticated users to read/list universities and nested collections
      allow get, list: if isAdmin() || isAuth();

      // University-scoped user profiles
      match /users/{userId} {
        allow create: if isAuth()
          && request.auth.uid == userId
          && request.resource.data.university == univId
          && request.resource.data.email == request.auth.token.email
          && request.resource.data.createdAt is timestamp;

        allow get: if isAuth() && request.auth.uid == userId;
        allow list: if isAdmin();

        allow update, delete: if isAuth() && request.auth.uid == userId
          && request.resource.data.email == resource.data.email
          && request.resource.data.university == resource.data.university;
      }

      // Rides under a university
      match /rides/{rideId} {
        // Allow anyone to list rides
        // Allow authenticated users to list rides filtered by driverId (for "My Offered Rides")
        allow list: if true;

        allow get: if true;

        allow create: if isAuth()
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.university == univId
          && request.resource.data.from is string
          && request.resource.data.to is string
          && request.resource.data.departureTime is timestamp
          && request.resource.data.availableSeats is int
          && request.resource.data.createdAt is timestamp;

        allow update, delete: if isAdmin() || (isAuth() && resource.data.createdBy == request.auth.uid);

        // Requests for a ride
        match /requests/{requestId} {
          allow create: if isAuth() && request.resource.data.passengerId == request.auth.uid;

          // Allow read if: admin, or user is the passenger, or user is the driver/creator of the ride
          allow get: if isAdmin() || (isAuth() && (
            (resource.data.passengerId is string && resource.data.passengerId == request.auth.uid)
            || (resource.data.driverId is string && resource.data.driverId == request.auth.uid)
          ));

          // Allow authenticated users to list requests. Client-side code validates ride ownership.
          // This prevents permission errors when users try to view requests for their rides.
          allow list: if isAdmin() || isAuth();

          allow update, delete: if isAdmin() || (isAuth() && (
            (resource.data.passengerId is string && resource.data.passengerId == request.auth.uid)
            || (resource.data.driverId is string && resource.data.driverId == request.auth.uid)
          ));
        }
      }

      // Bookings
      match /bookings/{bookingId} {
        allow create: if isAuth() && (request.resource.data.passengerId == request.auth.uid || request.resource.data.driverId == request.auth.uid);
        allow get: if isAdmin() || (isAuth() && (resource.data.passengerId == request.auth.uid || resource.data.driverId == request.auth.uid));
        // Relaxed: allow authenticated users to list bookings scoped to this university.
        // UI queries are filtered by passengerId/driverId; this prevents permission-denied loops seen in production.
        allow list: if isAdmin() || isAuth();
        allow update, delete: if isAdmin() || (isAuth() && (resource.data.passengerId == request.auth.uid || resource.data.driverId == request.auth.uid));
      }

      // Chats and messages
      match /chats/{chatId} {
        allow create: if isAuth() && request.resource.data.rideId is string && (
          (request.resource.data.participants is list && request.auth.uid in request.resource.data.participants)
          || (request.resource.data.passengerId is string && request.resource.data.providerId is string && (request.auth.uid == request.resource.data.passengerId || request.auth.uid == request.resource.data.providerId))
        );

        allow list, get: if isAuth() && (
          (resource.data.participants is list && request.auth.uid in resource.data.participants)
          || (resource.data.passengerId is string && resource.data.providerId is string && (request.auth.uid == resource.data.passengerId || request.auth.uid == resource.data.providerId))
        );

        allow update, delete: if isAdmin() || (isAuth() && (
          (resource.data.participants is list && request.auth.uid in resource.data.participants)
          || (resource.data.passengerId is string && resource.data.providerId is string && (request.auth.uid == resource.data.passengerId || request.auth.uid == resource.data.providerId))
        ));

        match /messages/{messageId} {
          allow create: if isAuth() && request.resource.data.senderId == request.auth.uid && (
            (get(/databases/$(database)/documents/universities/$(univId)/chats/$(chatId)).data.participants is list && request.auth.uid in get(/databases/$(database)/documents/universities/$(univId)/chats/$(chatId)).data.participants)
            || ((get(/databases/$(database)/documents/universities/$(univId)/chats/$(chatId)).data.passengerId is string) && (get(/databases/$(database)/documents/universities/$(univId)/chats/$(chatId)).data.providerId is string) && (request.auth.uid == get(/databases/$(database)/documents/universities/$(univId)/chats/$(chatId)).data.passengerId || request.auth.uid == get(/databases/$(database)/documents/universities/$(univId)/chats/$(chatId)).data.providerId))
          ) && request.resource.data.timestamp is timestamp && (request.resource.data.type in ['text','image','video','emoji']);

          allow list, get: if isAuth() && (
            (get(/databases/$(database)/documents/universities/$(univId)/chats/$(chatId)).data.participants is list && request.auth.uid in get(/databases/$(database)/documents/universities/$(univId)/chats/$(chatId)).data.participants)
            || ((get(/databases/$(database)/documents/universities/$(univId)/chats/$(chatId)).data.passengerId is string) && (get(/databases/$(database)/documents/universities/$(univId)/chats/$(chatId)).data.providerId is string) && (request.auth.uid == get(/databases/$(database)/documents/universities/$(univId)/chats/$(chatId)).data.passengerId || request.auth.uid == get(/databases/$(database)/documents/universities/$(univId)/chats/$(chatId)).data.providerId))
          );

          allow update, delete: if false;
        }
      }
    }

    // Per-user FCM tokens
    match /fcm_tokens/{uid} {
      // Allow users to create/update/delete their own token documents
      allow create, update, delete: if isAuth() && request.auth.uid == uid;
      // Allow the owner to read their token (clients commonly read to dedupe tokens).
      allow get: if isAuth() && request.auth.uid == uid;
      // Do not allow listing all tokens
      allow list: if false;
    }

    // Email verifications for university email verification
    match /email_verifications/{uid} {
      allow create: if false; // Only server can create
      allow get: if isAuth() && request.auth.uid == uid;
      allow update, delete: if false;
      allow list: if false;
    }
    // Default deny for any other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
